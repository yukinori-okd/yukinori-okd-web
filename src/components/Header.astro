---
import { MY_NAME } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeSwitcher from './ThemeSwitcher.astro';
---

<header>
    <nav>
        <h2><a href="/">{MY_NAME}</a></h2>
        <input
            id="nav-toggle"
            class="nav-toggle"
            type="checkbox"
            aria-label="Toggle navigation"
        />
        <label class="hamburger" for="nav-toggle" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
        </label>
        <div class="nav-menu">
            <div class="internal-links">
                <HeaderLink href="/">Home</HeaderLink>
                <HeaderLink href="/posts">Posts</HeaderLink>
                <HeaderLink href="/glossary">Glossary</HeaderLink>
                <HeaderLink href="/about">About</HeaderLink>
                <HeaderLink href="/works">Works</HeaderLink>
                <HeaderLink href="/contact">Contact</HeaderLink>
            </div>
            <div class="theme-switcher-container">
                <ThemeSwitcher />
            </div>
        </div>
    </nav>
</header>
<style>
    header {
        position: sticky;
        top: 0;
        z-index: 100;
        margin: 0;
        padding: 0 1em;
        background: rgb(var(--surface-base));
        box-shadow: 0 2px 8px rgba(var(--nav-shadow), 5%);
    }
    h2 {
        margin: 0;
        font-size: 1em;
    }

    h2 a,
    h2 a.active {
        text-decoration: none;
    }
    nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1em;
    }
    .nav-toggle {
        position: absolute;
        width: 1px;
        height: 1px;
        margin: -1px;
        padding: 0;
        overflow: hidden;
        clip: rect(0 0 0 0);
        white-space: nowrap;
        border: 0;
    }
    .hamburger {
        display: none;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        gap: 4px;
        width: 2.5rem;
        height: 2.5rem;
        background: transparent;
        cursor: pointer;
    }
    .hamburger span {
        display: block;
        width: 18px;
        height: 2px;
        background: rgb(var(--text-primary));
    }
    .nav-toggle:focus-visible + .hamburger {
        outline: 2px solid rgb(var(--accent));
        outline-offset: 2px;
    }
    .nav-menu {
        display: flex;
        align-items: center;
        gap: 0.5em;
        margin-left: auto;
    }
    .internal-links {
        display: flex;
        align-items: center;
        gap: 0;
    }
    nav a {
        padding: 1em 0.5em;
        color: rgb(var(--text-primary));
        border-bottom: 4px solid transparent;
        text-decoration: none;
    }
    nav a.active {
        text-decoration: none;
        border-bottom-color: rgb(var(--accent));
    }
    .theme-switcher-container {
        display: flex;
        align-items: center;
    }
    @media (max-width: 768px) {
        nav {
            flex-wrap: wrap;
        }
        .hamburger {
            display: inline-flex;
        }
        .nav-menu {
            display: none;
            width: 100%;
            margin-left: 0;
            flex-direction: column;
            align-items: stretch;
            gap: 0.75em;
            padding-bottom: 0.5em;
        }
        .nav-toggle:checked ~ .nav-menu {
            display: flex;
        }
        .internal-links {
            flex-direction: column;
            align-items: stretch;
        }
        nav a {
            padding: 0.75em 0;
        }
        .theme-switcher-container {
            padding: 0.5em 0;
        }
    }
</style>
