---
import type { TimelineItem } from '../types/timeline';

export type Props = {
    items: TimelineItem[];
};

const { items } = Astro.props;
---

<style>
    .timeline {
        position: relative;
        padding: 20px;
        min-height: 200px;
    }
    .timeline-item {
        position: relative;
        margin-bottom: 30px;
        padding-left: 40px;
    }
    .timeline-item::before {
        /* タイムラインの点を表すスタイル */
        content: '';
        position: absolute;
        left: -4px;
        top: 8px;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: transparent;
        border: 2px solid rgb(var(--text-body));
    }
    .timeline-date {
        font-weight: bold;
        color: rgb(var(--text-primary));
        margin-bottom: 5px;
    }
    .timeline-content {
        color: rgb(var(--text-body));
    }
    .timeline-divider {
        border-top: 1px solid rgb(var(--surface-sub));
        margin: 8px 0;
    }
    .timeline-institution {
        font-weight: 700;
        color: rgb(var(--text-primary));
    }
    .timeline-department {
        font-weight: 400;
        color: rgb(var(--text-body));
        font-size: 0.8em;
    }
    .timeline-degree {
        font-weight: 400;
        color: rgb(var(--text-body));
        font-size: 0.8em;
    }
    .timeline-status {
        color: rgb(var(--text-secondary));
        font-size: 0.8em;
    }
</style>

<div class="timeline">
    {items.map((item) => (
        <div class="timeline-item">
            <div class="timeline-date">{item.startDate} ー {item.endDate}</div>
            <div class="timeline-divider"></div>
            <div class="timeline-content">
                <div class="timeline-institution">{item.institution}</div>
                <div class="timeline-department">{item.department}</div>
                <div class="timeline-degree">{item.degree}</div>
                {item.status && <div class="timeline-status">{item.status}</div>}
            </div>
        </div>
    ))}
</div>
