---
export interface Props {
    items: Array<{
        date: string;
        content: string;
    }>;
}

const { items } = Astro.props;
---

<style>
    .timeline {
        position: relative;
        padding: 20px;
        min-height: 200px;
    }
    .timeline-item {
        position: relative;
        margin-bottom: 30px;
        padding-left: 40px;
    }
    .timeline-item::before {
        /* タイムラインの点を表すスタイル */
        content: '';
        position: absolute;
        left: -4px;
        top: 8px;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: transparent;
        border: 2px solid rgb(var(--gray-dark));
    }
    .timeline-date {
        font-weight: bold;
        color: rgb(var(--black));
        margin-bottom: 5px;
    }
    .timeline-content {
        color: rgb(var(--gray-dark));
    }
</style>

<div class="timeline">
    {items.map((item) => (
        <div class="timeline-item">
            <div class="timeline-date">{item.date}</div>
            <div class="timeline-content">{item.content}</div>
        </div>
    ))}
</div>
